{
   "version": 6,
   "configurePresets": [
      {
         "name": "Win64-Debug",
         "displayName": "Debug",
         "generator": "Visual Studio 18 2026",
         "binaryDir": "${sourceDir}/out/Win64/Debug",
         "cacheVariables": {
            "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "CMAKE_BUILD_TYPE": "Debug",
            "INTEGRATION_TEST": "False",
            "CMAKE_CXX_FLAGS": "/EHsc",
            "CMAKE_C_FLAGS_DEBUG": "/MTd /Zi /Ob0 /Od /RTC1",
            "CMAKE_CXX_FLAGS_DEBUG": "/MTd /Zi /Ob0 /Od /RTC1",
            "VCPKG_TARGET_TRIPLET": "x64-windows-static",
            "wxUSE_WEBVIEW_EDGE": "True",
            "wxUSE_WEBVIEW_EDGE_STATIC": "True"
         }
      },
      {
         "name": "Win64-Integration",
         "displayName": "Integration",
         "inherits": "Win64-Debug",
         "binaryDir": "${sourceDir}/out/Win64/Integration",
         "cacheVariables": {
            "INTEGRATION_TEST": "True"
         }
      },
      {
         "name": "Win64-Release",
         "displayName": "Release",
         "inherits": "Win64-Debug",
         "binaryDir": "${sourceDir}/out/Win64/Release",
         "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "CMAKE_C_FLAGS_RELEASE": "/MT /O2 /Ob2",
            "CMAKE_CXX_FLAGS_RELEASE": "/MT /O2 /Ob2"
         }
      }
   ],
   "buildPresets": [
      {
         "name": "Win64-Debug",
         "displayName": "Debug",
         "configurePreset": "Win64-Debug",
         "configuration": "Debug"
      },
      {
         "name": "Win64-Integration",
         "displayName": "Debug Integration",
         "inherits": "Win64-Debug",
         "configurePreset": "Win64-Integration"
      },
      {
         "name": "Win64-Release",
         "displayName": "Release",
         "configurePreset": "Win64-Release",
         "configuration": "Release"
      }
   ],
   "testPresets": [
      {
         "name": "Win64-Debug",
         "displayName": "Debug",
         "configurePreset": "Win64-Debug",
         "configuration": "Debug"
      },
      {
         "name": "Win64-Integration",
         "displayName": "Debug Integration",
         "inherits": "Win64-Debug",
         "configurePreset": "Win64-Integration"
      },
      {
         "name": "Win64-Release",
         "displayName": "Release",
         "configurePreset": "Win64-Release",
         "configuration": "Release"
      }
   ]
}